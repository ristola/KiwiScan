#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="/tmp/kiwiscan-installer-postinstall.log"
{
  echo "[$(date)] Starting KiwiScan postinstall"
  if command -v /usr/local/bin/kiwiscan-install >/dev/null 2>&1; then
    /usr/local/bin/kiwiscan-install /opt/kiwi_scan_prod
    echo "[$(date)] KiwiScan install completed"
  else
    echo "[$(date)] ERROR: /usr/local/bin/kiwiscan-install not found"
    exit 1
  fi
} >>"$LOG_FILE" 2>&1

exit 0
